<div class="container mt-4">
  <h1 class="mb-4">Restaurantes</h1>

  <div class="row row-cols-1 row-cols-md-2 g-4">
    <% @restaurants.each do |restaurant| %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title"><%= restaurant.name %></h5>
            <p class="card-text"><strong>Category:</strong> <%= restaurant.category.capitalize %></p>
            <p class="card-text"><strong>Address:</strong> <%= restaurant.address %></p>
            <%# <p class="card-text"><strong>Number of reviews: </strong><%= restaurant.reviews.count(:rating)&.round(1) || "0" %>
            <p class="card-text"><strong>Rating: </strong><%= restaurant.reviews.average(:rating)&.round(1) || "No ratings yet" %>
          </div>
          <div class="card-footer bg-transparent border-top-0">
            <%= link_to "View", restaurant_path(restaurant), class: "btn btn-sm btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
